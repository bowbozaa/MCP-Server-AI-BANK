{
  "name": "🤖 Mosses Autonomous Orchestrator",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "triggerAtHour": 6
            }
          ]
        }
      },
      "id": "schedule-morning",
      "name": "🌅 Morning (06:00)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 0],
      "notes": "Health check + Daily plan"
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "triggerAtHour": 9
            }
          ]
        }
      },
      "id": "schedule-content",
      "name": "📝 Content (09:00)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 300],
      "notes": "Content production + Compliance"
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "triggerAtHour": 14
            }
          ]
        }
      },
      "id": "schedule-analytics",
      "name": "📊 Analytics (14:00)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 600],
      "notes": "Data analysis + Report"
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "triggerAtHour": 18
            }
          ]
        }
      },
      "id": "schedule-maintenance",
      "name": "🔧 Maintenance (18:00)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 900],
      "notes": "System maintenance + Backup"
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "triggerAtHour": 22
            }
          ]
        }
      },
      "id": "schedule-summary",
      "name": "📈 Summary (22:00)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 1200],
      "notes": "Daily summary + Tomorrow plan"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "round",
              "name": "round",
              "value": "={{ $node.name }}",
              "type": "string"
            },
            {
              "id": "run_id",
              "name": "run_id",
              "value": "={{ 'run_' + $now.format('yyyyMMdd_HHmmss') }}",
              "type": "string"
            },
            {
              "id": "timestamp",
              "name": "timestamp",
              "value": "={{ $now.toISO() }}",
              "type": "string"
            }
          ]
        }
      },
      "id": "set-context-morning",
      "name": "Set Context (Morning)",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [250, 0]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "round",
              "name": "round",
              "value": "content",
              "type": "string"
            },
            {
              "id": "run_id",
              "name": "run_id",
              "value": "={{ 'run_' + $now.format('yyyyMMdd_HHmmss') }}",
              "type": "string"
            },
            {
              "id": "day_of_week",
              "name": "day_of_week",
              "value": "={{ $now.format('EEEE') }}",
              "type": "string"
            }
          ]
