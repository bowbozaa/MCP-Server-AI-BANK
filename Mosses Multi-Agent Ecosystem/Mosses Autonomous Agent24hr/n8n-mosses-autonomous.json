            },
            {
              "id": "run_id",
              "name": "run_id",
              "value": "={{ 'run_' + $now.format('yyyyMMdd_HHmmss') }}",
              "type": "string"
            }
          ]
        }
      },
      "id": "set-context-analytics",
      "name": "Set Context (Analytics)",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [250, 600]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
