    },
    "Context: Summary": {
      "main": [[{ "node": "Agent: Daily Summary", "type": "main", "index": 0 }]]
    },

    "Agent: DevOps Health": {
      "main": [[{ "node": "Format: Morning", "type": "main", "index": 0 }]]
    },
    "Agent: Content Strategist": {
      "main": [[{ "node": "Format: Content", "type": "main", "index": 0 }]]
    },
    "Agent: Data Analyst": {
      "main": [[{ "node": "Format: Analytics", "type": "main", "index": 0 }]]
    },
    "Agent: DevOps Maintenance": {
      "main": [[{ "node": "Format: Maintenance", "type": "main", "index": 0 }]]
    },
    "Agent: Daily Summary": {
      "main": [[{ "node": "Format: Summary", "type": "main", "index": 0 }]]
    },

    "Format: Morning": {
      "main": [[{ "node": "Log to Supabase", "type": "main", "index": 0 }]]
    },
    "Format: Content": {
      "main": [[{ "node": "Log to Supabase", "type": "main", "index": 0 }]]
    },
    "Format: Analytics": {
      "main": [[{ "node": "Log to Supabase", "type": "main", "index": 0 }]]
    },
    "Format: Maintenance": {
      "main": [[{ "node": "Log to Supabase", "type": "main", "index": 0 }]]
